# ── Database Configurations ──────────────────────────────────────────
# Hostname or IP of the TimescaleDB/PostgreSQL database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hidrometeorology
DATABASE_USER=hidro_user
# WARNING: Set a strong password in your local .env file. Do not use default passwords in production.
DATABASE_PASSWORD=your_secure_password

# ── ADS-B SDR Connection Configurations ──────────────────────────────
# Host/port from which raw ADS-B data is streamed (e.g. dump1090/dump978/Beast server)
ADSB_HOST=localhost
ADSB_PORT=30002

# ── Application Settings ─────────────────────────────────────────────
# Database insert batch interval (in seconds)
BATCH_INTERVAL_SEC=60
# Endpoint URL to sync database rows (if uploader sync mode is enabled)
UPLOAD_API_URL=https://bytenusa.cloud/api/v1/adsb/bulk

# ── Web Server Configurations ────────────────────────────────────────
# IP to bind the FastAPI web server to. 
# Defaults to 127.0.0.1 (local only) for security. Use 0.0.0.0 to expose to the LAN/Internet.
WEB_SERVER_HOST=127.0.0.1
WEB_SERVER_PORT=8000

# Comma-separated list of allowed origins for Web Server CORS requests.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Secret API Key required for querying GET /api/aircraft (via X-API-Key header).
# If left empty, the application will auto-generate a secure random 32-character hex key at boot.
WEB_SERVER_API_KEY=

# ── Antenna Reference Coordinates & Calibration ─────────────────────
# Coordinates of the receiver antenna. Used to calculate distance and filter out-of-range telemetry.
ANTENNA_LAT=-6.2000
ANTENNA_LON=106.8166
# Maximum range (in km) to filter out telemetry reports that are too far away
MAX_RECEIVER_RANGE_KM=500.0
